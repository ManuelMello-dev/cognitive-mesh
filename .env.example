# ═══════════════════════════════════════════════
# Runtime Configuration
# ═══════════════════════════════════════════════
# PORT is set by Railway automatically. For local development, use 8081.
PORT=8081

# ═══════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════
# PostgreSQL — required for persistent memory (long-term, short-term, episodic)
# Either POSTGRES_URL or DATABASE_URL may be used; managed providers often inject DATABASE_URL.
POSTGRES_URL=postgresql://postgres:password@localhost:5432/cognitive_mesh
DATABASE_URL=
POSTGRES_PASSWORD=password
POSTGRES_CONNECT_TIMEOUT=15
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=3
POSTGRES_COMMAND_TIMEOUT=30
# Milvus — optional, used for semantic vector search
MILVUS_HOST=localhost
MILVUS_PORT=19530
# Redis — optional, used for fast caching layer
# Either REDIS_URL or REDIS_HOST/REDIS_PORT may be used.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════════
# Data Plugin Configuration
# ═══════════════════════════════════════════════
# Disable the built-in MarketPlugin (set to true to run domain-agnostic only)
DISABLE_MARKET_PLUGIN=false
# Symbols to track via MarketPlugin (comma-separated)
SYMBOLS=AAPL,MSFT,GOOGL,TSLA,NVDA,BTC,ETH
# Update interval in seconds for data collection
UPDATE_INTERVAL=60

# ═══════════════════════════════════════════════
# Financial Data API Keys (MarketPlugin only)
# ═══════════════════════════════════════════════
ALPHA_VANTAGE_API_KEY=
POLYGON_IO_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ═══════════════════════════════════════════════
# Cognitive System Configuration
# ═══════════════════════════════════════════════
# How often (in seconds) to save full cognitive state to Postgres
CHECKPOINT_INTERVAL=300
# Cognitive loop iterations between self-evolution cycles (~5 min default)
EVOLUTION_INTERVAL=3000

# ═══════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FILE=./logs/cognitive_mesh.log

# ═══════════════════════════════════════════════
# Node Configuration (ZeroMQ distributed mesh)
# ═══════════════════════════════════════════════
NODE_ID=global_mind_01
LISTEN_PORT=5555
PUB_PORT=5556
SUB_PORT=5557

# ═══════════════════════════════════════════════
# Circuit Breaker Configuration
# ═══════════════════════════════════════════════
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=60
